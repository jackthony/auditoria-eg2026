# ──────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# ──────────────────────────────────────────────────────────────
# Jupyter
# ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ──────────────────────────────────────────────────────────────
# IDE
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ──────────────────────────────────────────────────────────────
# Claude Code runtime
# ──────────────────────────────────────────────────────────────
.claude/scheduled_tasks.lock
.claude/worktrees/
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────
# Outputs regenerables — NO se commitean
# Los archivos derivados se pueden reconstruir desde captures/
# ──────────────────────────────────────────────────────────────
data/processed/*.csv
data/processed/*.json
reports/figures/*.png
reports/*.docx
reports/*.pdf
reports/findings.json
reports/impugnadas_por_region.csv
reports/serie_temporal.csv

# HuggingFace dataset (419MB, vive en HF — regenerable con build_hf_dataset.py)
reports/hf_dataset/*.parquet
reports/hf_dataset/*.csv

# DuckDB regenerable (99MB) — rebuild con scripts/build_duckdb_and_fix.py
reports/hallazgos_*/eg2026.duckdb
reports/hallazgos_*/eg2026.duckdb.wal

# Excepciones: mantenemos los README que documentan la carpeta
!data/processed/.gitkeep
!reports/figures/.gitkeep
!reports/.gitkeep

# ──────────────────────────────────────────────────────────────
# Capturas: SÍ se commitean, incluidas
# Solo se ignoran archivos temporales dentro de captures/
# ──────────────────────────────────────────────────────────────
captures/**/*.tmp
captures/**/.DS_Store

# MESA-03: raw gzipped responses mesa-a-mesa (22GB). MANIFEST+summary SÍ van a git.
captures/**/mesas/*.json.gz

# ──────────────────────────────────────────────────────────────
# Evidencia sensible — a criterio del partido si commitear o no
# Por defecto, los PDFs y fotos de copias físicas NO se suben a
# repos públicos hasta revisión legal
# ──────────────────────────────────────────────────────────────
evidence/personero_copies/*.pdf
evidence/personero_copies/*.jpg
evidence/personero_copies/*.png
evidence/personero_copies/*.jpeg
!evidence/personero_copies/README.md

# ──────────────────────────────────────────────────────────────
# Secretos (por si acaso)
# ──────────────────────────────────────────────────────────────
.env
.env.local
*.key
*.pem
secrets/

# PERITO-01 — ZIPs periciales generados (artefactos locales)
reports/perito/

# ──────────────────────────────────────────────────────────────
# Claude Code — mayoría PRIVADA, EXCEPTO FORENSIS público
# Razón forense: prompts de agentes FORENSIS deben ser auditables públicamente
# para credibilidad del agente autónomo. agents/ + rules/ del proyecto = OSS.
# settings/worktrees/locks = privados.
# ──────────────────────────────────────────────────────────────
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# ──────────────────────────────────────────────────────────────
# Informe privado para cliente original (RP) — NO publicar
# Ver README.md §9 (Declaración de transparencia)
# ──────────────────────────────────────────────────────────────
scripts/build_pdf.py
scripts/build_pdf_v*.py
scripts/build_memorial_pdf.py


# Node (Cloudflare Worker)
node_modules/
.wrangler/
dist/
reports/mesas_presidencial.csv
