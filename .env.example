# Copiar a .env (nunca commit) y rellenar.
# TG-BOT-01 — Bot Telegram @AuditoriaEG2026
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Worker proxy para walker mesa-a-mesa (fetch_onpe_mesas*.py)
ONPE_PROXY_BASE=https://onpe-proxy-neuracode.jackgptgod.workers.dev

# HuggingFace — DATA-MARKET (build_hf_dataset.py)
HF_TOKEN=hf_...

# Pinata IPFS — IPFS-01 (pin_to_ipfs.py)
# Solo necesitas JWT (reemplaza API key + secret). Dashboard → API Keys → New.
# NOTA 2026-04-20: Pinata free ya no sirve contenido via mypinata.cloud.
# Se mantiene como backup proof (archivo queda en red IPFS). Gateway no usable.
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=

# Filebase IPFS — IPFS-01 (pin_to_filebase.py)
# Free 5GB, S3-compatible + IPFS, gateway publico funciona sin custom domain.
# Dashboard: https://console.filebase.com/ -> Access Keys
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=neuracode-audit-eg2026
FILEBASE_RPC_TOKEN=

# ── FORENSIS agente IA ──
# Anthropic Claude API (orchestrator + 12 subagentes)
# Consola: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity API (web fact-check para expert-synthesizer + publishing-guard)
# Consola: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...
